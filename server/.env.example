FRONTIER_API_KEY=          # Developer API key from third-party/developers/{id}/rotate-key
AGENT_EOA_PRIVATE_KEY=     # Hex private key for the agent's EOA registered in AgentRegistry
WEBHOOK_PUBLIC_KEY=        # Ed25519 public key from thirdParty:createWebhook response
AGENT_REGISTRY_ADDRESS=    # 0x... address of the deployed AgentRegistry contract in sandbox
SANDBOX_API_BASE=https://api.sandbox.frontiertower.io
SANDBOX_RPC_URL=           # JSON-RPC URL of the chain where AgentRegistry lives
